<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#1F1B24">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingLeft="32dp"
        android:paddingTop="32dp"
        android:paddingRight="32dp"
        android:paddingBottom="48dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Feste &amp; Feiertage"
            android:textColor="#FFFFFF"
            android:textSize="40sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEaster"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="120dp"
            android:text="🐣 Ostern"
            android:textAllCaps="false"
            android:textColor="#E65100"
            android:textSize="42sp"
            android:textStyle="bold"
            app:backgroundTint="#FFF9C4"
            app:cornerRadius="50dp"
            app:elevation="12dp"
            app:strokeColor="#F57F17"
            app:strokeWidth="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPentecost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="100dp"
            android:text="🕊️ Pfingsten"
            android:textAllCaps="false"
            android:textColor="#01579B"
            android:textSize="36sp"
            android:textStyle="bold"
            app:backgroundTint="#E1F5FE"
            app:cornerRadius="50dp"
            app:elevation="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChristmas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="100dp"
            android:text="🎄 Weihnachten"
            android:textAllCaps="false"
            android:textColor="#B71C1C"
            android:textSize="36sp"
            android:textStyle="bold"
            app:backgroundTint="#FFCDD2"
            app:cornerRadius="50dp"
            app:elevation="8dp" />

    </LinearLayout>
</ScrollView>
