<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#1F1B24">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingLeft="32dp"
        android:paddingTop="32dp"
        android:paddingRight="32dp"
        android:paddingBottom="48dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grimms Märchen"
            android:textColor="#FFFFFF"
            android:textSize="40sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGrimmMixed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="120dp"
            android:text="Märchen Mix"
            android:textAllCaps="false"
            android:textColor="#3E2723"
            android:textSize="42sp"
            android:textStyle="bold"
            app:backgroundTint="#FFCC80"
            app:cornerRadius="50dp"
            app:elevation="12dp"
            app:strokeColor="#E65100"
            app:strokeWidth="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHansel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="100dp"
            android:text="Hänsel &amp; Gretel"
            android:textAllCaps="false"
            android:textColor="#1B5E20"
            android:textSize="36sp"
            android:textStyle="bold"
            app:backgroundTint="#C8E6C9"
            app:cornerRadius="50dp"
            app:elevation="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRedRidingHood"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="100dp"
            android:text="Rotkäppchen"
            android:textAllCaps="false"
            android:textColor="#B71C1C"
            android:textSize="36sp"
            android:textStyle="bold"
            app:backgroundTint="#FFCDD2"
            app:cornerRadius="50dp"
            app:elevation="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSnowWhite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="100dp"
            android:text="Schneewittchen"
            android:textAllCaps="false"
            android:textColor="#0D47A1"
            android:textSize="36sp"
            android:textStyle="bold"
            app:backgroundTint="#BBDEFB"
            app:cornerRadius="50dp"
            app:elevation="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFrogPrince"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="100dp"
            android:text="Froschkönig"
            android:textAllCaps="false"
            android:textColor="#33691E"
            android:textSize="36sp"
            android:textStyle="bold"
            app:backgroundTint="#DCEDC8"
            app:cornerRadius="50dp"
            app:elevation="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCinderella"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="100dp"
            android:text="Aschenputtel"
            android:textAllCaps="false"
            android:textColor="#F57F17"
            android:textSize="36sp"
            android:textStyle="bold"
            app:backgroundTint="#FFF9C4"
            app:cornerRadius="50dp"
            app:elevation="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSleeping"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="100dp"
            android:text="Dornröschen"
            android:textAllCaps="false"
            android:textColor="#880E4F"
            android:textSize="36sp"
            android:textStyle="bold"
            app:backgroundTint="#F8BBD0"
            app:cornerRadius="50dp"
            app:elevation="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHolle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="100dp"
            android:text="Frau Holle"
            android:textAllCaps="false"
            android:textColor="#01579B"
            android:textSize="36sp"
            android:textStyle="bold"
            app:backgroundTint="#B3E5FC"
            app:cornerRadius="50dp"
            app:elevation="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRumpel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="100dp"
            android:text="Rumpelstilzchen"
            android:textAllCaps="false"
            android:textColor="#4E342E"
            android:textSize="33sp"
            android:textStyle="bold"
            app:backgroundTint="#D7CCC8"
            app:cornerRadius="50dp"
            app:elevation="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="100dp"
            android:text="Wolf &amp; 7 Geißlein"
            android:textAllCaps="false"
            android:textColor="#3E2723"
            android:textSize="33sp"
            android:textStyle="bold"
            app:backgroundTint="#FFCCBC"
            app:cornerRadius="50dp"
            app:elevation="8dp" />

    </LinearLayout>
</ScrollView>
